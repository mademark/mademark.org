Options -Indexes -MultiViews
DirectoryIndex index.html

# Correct content type for JSON-LD files
<IfModule mod_mime.c>
  AddType application/ld+json .json
</IfModule>

# Correct content type for SVG files
<IfModule mod_mime.c>
  AddType image/svg+xml .svg
</IfModule>

# Force download for ZIP files
<FilesMatch "\.(zip)$">
  ForceType application/octet-stream
  Header set Content-Disposition attachment
</FilesMatch>

# Caching. Images rarely change, so cache them long. CSS/JS/HTML change with
# each release, so they revalidate on every visit (a cheap 304 when unchanged)
# — this way site updates reach returning visitors on their next load instead
# of being pinned for up to a week by the old CSS cache.
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType image/svg+xml "access plus 1 month"
  ExpiresByType image/png "access plus 1 month"
  ExpiresByType application/ld+json "access plus 1 hour"
</IfModule>

<IfModule mod_headers.c>
  # no-cache means "cache but always revalidate before use" — the browser
  # sends a conditional request and the server answers 304 (tiny) when the
  # file is unchanged, so we keep the speed but never serve stale CSS/JS/HTML.
  <FilesMatch "\.(css|js|html)$">
    Header set Cache-Control "no-cache"
  </FilesMatch>
  # The service worker file must never be cached, or the browser won't see new
  # versions — and then no cache update (of anything) can ever propagate.
  <FilesMatch "^sw\.js$">
    Header set Cache-Control "no-store, no-cache, must-revalidate"
  </FilesMatch>
</IfModule>

# Block web access to the local version archive (should never be uploaded,
# but belt-and-suspenders if it is)
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteRule ^_releases(/|$) - [R=404,L]
</IfModule>

# Security headers
<IfModule mod_headers.c>
  Header set X-Content-Type-Options "nosniff"
  Header set X-Frame-Options "SAMEORIGIN"
  Header set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>

# Moved pages (v2.0 audience IA, July 2026)
RedirectMatch 301 ^/use-made-mark(/.*)?$ /label/
RedirectMatch 301 ^/for-ai-users(/.*)?$ /use-with-ai/

# Redirect www to non-www
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteCond %{HTTP_HOST} ^www\.mademark\.org [NC]
  RewriteRule ^(.*)$ https://mademark.org/$1 [R=301,L]
</IfModule>

# Force HTTPS
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteCond %{HTTPS} off
  RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [R=301,L]
</IfModule>
