# Bluehost deployment settings — copy this file to `deploy.env` and fill in.
# `deploy.env` is gitignored so your real credentials never get committed.
#
# Find these in your Bluehost cPanel:
#   - Enable SSH access under "SSH Access" / "Advanced".
#   - SSH_HOST is usually your domain or the server hostname cPanel shows.
#   - SSH_USER is your cPanel username.
#   - REMOTE_PATH is the web root for mademark.org. For a primary domain this
#     is usually "public_html"; for an add-on domain it may be
#     "public_html/mademark.org". Confirm in cPanel File Manager.
#   - SSH_PORT is 22 on most Bluehost plans (some use 2222).

SSH_HOST="mademark.org"
SSH_USER="your_cpanel_username"
REMOTE_PATH="public_html"
SSH_PORT="22"
