# ExifTool config for the Made Mark XMP namespace (https://mademark.org/ns/).
#
# Uses the "made" XML prefix rather than the spec doc's illustrative "mm:"
# prefix, because ExifTool internally reserves the "mm" prefix for Adobe's
# xapMM (Media Management) namespace — reusing it causes read-back to be
# mis-grouped even though the write succeeds. Per RDF/XMP, prefixes are
# arbitrary; conformant consumers match by namespace URI
# (https://mademark.org/ns/), not by the literal prefix string, so this is
# spec-compliant. Verified round-trip: ExifTool resolves the tag group to
# "XMP-made" (derived from the NAMESPACE prefix below, not the GROUPS
# setting), serialized with xmlns:made='https://mademark.org/ns/'.
#
# Usage: exiftool -config mademark.exiftool.config -XMP-made:Mark=... file

%Image::ExifTool::UserDefined = (
    'Image::ExifTool::XMP::Main' => {
        mademark => {
            SubDirectory => {
                TagTable => 'Image::ExifTool::UserDefined::mademark',
            },
        },
    },
);

%Image::ExifTool::UserDefined::mademark = (
    GROUPS        => { 0 => 'XMP', 1 => 'XMP-mademark', 2 => 'Other' },
    NAMESPACE     => { 'made' => 'https://mademark.org/ns/' },
    WRITABLE      => 'string',
    Mark          => { },
    Model         => { },
    Provider      => { },
    SourceLicense => { },
);

1; #end
